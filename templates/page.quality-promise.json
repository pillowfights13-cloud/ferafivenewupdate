        "liquid": "<style>\n  /* ═══════════════════════════════════════\n     FÉRAFIVE — OUR STANDARDS PAGE\n     Paste into Shopify Custom Liquid section\n     Colors: #AC1D21, #000000, #FFFFFF\n  ═══════════════════════════════════════ */\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Montserrat:wght@300;400;500;600&display=swap');\n\n  .ff-standards *, .ff-standards *::before, .ff-standards *::after { margin: 0; padding: 0; box-sizing: border-box; }\n\n  .ff-standards {\n    --red: #AC1D21;\n    --red-dark: #8C181B;\n    --red-light: rgba(172,29,33,0.08);\n    --black: #000000;\n    --black-soft: #1A1A1A;\n    --gray-dark: #333333;\n    --gray: #666666;\n    --gray-light: #999999;\n    --gray-border: #E0E0E0;\n    --gray-bg: #F5F5F5;\n    --white: #FFFFFF;\n    --font-display: 'Cormorant Garamond', Georgia, serif;\n    --font-body: 'Montserrat', 'Helvetica Neue', Arial, sans-serif;\n    --max-w: 1200px;\n\n    font-family: var(--font-body);\n    color: var(--black);\n    line-height: 1.7;\n    font-weight: 300;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .ff-standards a { color: inherit; text-decoration: none; }\n  .ff-standards img { max-width: 100%; display: block; }\n\n  .ff-wrap {\n    max-width: var(--max-w);\n    margin: 0 auto;\n    padding: 0 40px;\n  }\n\n  /* ═══════════ HERO ═══════════ */\n  .ff-hero {\n    padding: 80px 0 60px;\n    text-align: center;\n    position: relative;\n    background: var(--white);\n  }\n  .ff-hero::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 50%;\n    transform: translateX(-50%);\n    width: 40px; height: 3px;\n    background: var(--red);\n  }\n  .ff-hero-eyebrow {\n    font-size: 11px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: var(--red);\n    font-weight: 600;\n    margin-bottom: 24px;\n    padding-top: 32px;\n    opacity: 0;\n    animation: ffFadeUp 0.7s ease 0.15s forwards;\n  }\n  .ff-hero h1 {\n    font-family: var(--font-display);\n    font-size: clamp(34px, 5vw, 58px);\n    font-weight: 300;\n    line-height: 1.15;\n    color: var(--black);\n    margin-bottom: 24px;\n    opacity: 0;\n    animation: ffFadeUp 0.7s ease 0.3s forwards;\n  }\n  .ff-hero h1 em { font-style: italic; font-weight: 400; }\n  .ff-hero-desc {\n    max-width: 600px;\n    margin: 0 auto;\n    font-size: 15px;\n    color: var(--gray);\n    line-height: 1.85;\n    opacity: 0;\n    animation: ffFadeUp 0.7s ease 0.45s forwards;\n  }\n\n  /* ═══════════ SECTION COMMON ═══════════ */\n  .ff-section {\n    padding: 100px 0;\n  }\n  .ff-section-alt {\n    background: var(--gray-bg);\n  }\n  .ff-section-dark {\n    background: var(--black);\n    color: var(--white);\n  }\n  .ff-eyebrow {\n    font-size: 11px;\n    letter-spacing: 3.5px;\n    text-transform: uppercase;\n    color: var(--red);\n    font-weight: 600;\n    margin-bottom: 14px;\n  }\n  .ff-title {\n    font-family: var(--font-display);\n    font-size: clamp(26px, 3.2vw, 42px);\n    font-weight: 300;\n    line-height: 1.25;\n    margin-bottom: 20px;\n  }\n  .ff-title em { font-style: italic; font-weight: 400; }\n  .ff-body {\n    font-size: 15px;\n    color: var(--gray);\n    line-height: 1.85;\n    max-width: 620px;\n  }\n  .ff-section-dark .ff-body { color: rgba(255,255,255,0.6); }\n  .ff-section-dark .ff-eyebrow { color: var(--red); }\n\n  /* ═══════════ CREDENTIALS GRID ═══════════ */\n  .ff-creds {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 20px;\n    margin-top: 52px;\n  }\n  .ff-cred-card {\n    background: var(--white);\n    border: 1px solid var(--gray-border);\n    padding: 32px 24px;\n    text-align: center;\n    transition: transform 0.35s ease, box-shadow 0.35s ease;\n  }\n  .ff-cred-card:hover {\n    transform: translateY(-3px);\n    box-shadow: 0 10px 30px rgba(0,0,0,0.06);\n  }\n  .ff-cred-icon {\n    width: 50px; height: 50px;\n    margin: 0 auto 18px;\n    border-radius: 50%;\n    background: var(--red-light);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .ff-cred-icon svg {\n    width: 22px; height: 22px;\n    stroke: var(--red);\n    stroke-width: 1.5;\n    fill: none;\n  }\n  .ff-cred-card h4 {\n    font-family: var(--font-display);\n    font-size: 19px;\n    font-weight: 500;\n    margin-bottom: 8px;\n    color: var(--black);\n  }\n  .ff-cred-card p {\n    font-size: 13px;\n    color: var(--gray);\n    line-height: 1.6;\n  }\n\n  /* ═══════════ SPLIT LAYOUT ═══════════ */\n  .ff-split {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 72px;\n    align-items: center;\n  }\n  .ff-split.reverse .ff-split-visual { order: 2; }\n  .ff-split.reverse .ff-split-content { order: 1; }\n\n  .ff-visual-box {\n    aspect-ratio: 4/5;\n    background: linear-gradient(145deg, var(--gray-bg) 0%, var(--gray-border) 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n  }\n  .ff-section-alt .ff-visual-box {\n    background: linear-gradient(145deg, var(--white) 0%, var(--gray-border) 100%);\n  }\n  .ff-visual-box .ff-vb-inner {\n    text-align: center;\n    color: var(--gray-light);\n  }\n  .ff-visual-box .ff-vb-inner svg {\n    width: 44px; height: 44px;\n    stroke: var(--red);\n    stroke-width: 1;\n    margin-bottom: 10px;\n  }\n  .ff-visual-box .ff-vb-inner p {\n    font-size: 11px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--gray-light);\n  }\n\n  /* ═══════════ PDF EMBED ═══════════ */\n  .ff-pdf-embed {\n    aspect-ratio: 4/5;\n    position: relative;\n    border: 1px solid var(--gray-border);\n    background: var(--white);\n    overflow: hidden;\n  }\n  .ff-pdf-embed iframe {\n    width: 100%;\n    height: 100%;\n    border: none;\n    display: block;\n  }\n  .ff-pdf-embed .ff-pdf-fallback {\n    position: absolute;\n    bottom: 0; left: 0; right: 0;\n    padding: 14px 20px;\n    background: linear-gradient(0deg, rgba(0,0,0,0.7) 0%, transparent 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .ff-pdf-embed .ff-pdf-fallback a {\n    font-size: 11px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    font-weight: 600;\n    color: var(--white);\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    transition: opacity 0.3s;\n  }\n  .ff-pdf-embed .ff-pdf-fallback a:hover { opacity: 0.8; }\n  .ff-pdf-embed .ff-pdf-fallback a svg {\n    width: 14px; height: 14px;\n    stroke: var(--white);\n    stroke-width: 2;\n    fill: none;\n  }\n\n  /* ═══════════ STABILITY TABLES ═══════════ */\n  .ff-stab-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 32px;\n    margin-top: 44px;\n  }\n  .ff-stab-card {\n    background: var(--white);\n    border: 1px solid var(--gray-border);\n    overflow: hidden;\n  }\n  .ff-stab-header {\n    padding: 20px 24px;\n    border-bottom: 1px solid var(--gray-border);\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n  .ff-stab-header h4 {\n    font-family: var(--font-display);\n    font-size: 19px;\n    font-weight: 500;\n  }\n  .ff-badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    font-size: 10px;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    font-weight: 600;\n    padding: 4px 11px;\n    border-radius: 20px;\n    background: #E8F5E9;\n    color: #2E7D32;\n  }\n  .ff-badge svg {\n    width: 11px; height: 11px;\n    stroke: #2E7D32;\n    stroke-width: 2.5;\n    fill: none;\n  }\n  .ff-stab-body { padding: 24px; }\n  .ff-stab-body table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n  }\n  .ff-stab-body th {\n    text-align: left;\n    font-weight: 500;\n    font-size: 10px;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    color: var(--gray-light);\n    padding: 8px 0;\n    border-bottom: 1px solid var(--gray-border);\n  }\n  .ff-stab-body td {\n    padding: 10px 0;\n    border-bottom: 1px solid rgba(224,224,224,0.5);\n    color: var(--gray);\n  }\n  .ff-stab-body tr:last-child td {\n    border-bottom: none;\n    font-weight: 500;\n    color: var(--black);\n  }\n\n  /* ═══════════ TIMELINE ═══════════ */\n  .ff-timeline {\n    position: relative;\n    margin-top: 36px;\n    padding-left: 36px;\n  }\n  .ff-timeline::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 10px;\n    width: 1px; height: 100%;\n    background: var(--gray-border);\n  }\n  .ff-tl-item {\n    position: relative;\n    padding-bottom: 32px;\n    padding-left: 32px;\n  }\n  .ff-tl-item:last-child { padding-bottom: 0; }\n  .ff-tl-dot {\n    position: absolute;\n    left: -36px; top: 3px;\n    width: 20px; height: 20px;\n    border-radius: 50%;\n    background: var(--white);\n    border: 2px solid var(--red);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .ff-section-alt .ff-tl-dot { background: var(--gray-bg); }\n  .ff-tl-dot::after {\n    content: '';\n    width: 7px; height: 7px;\n    border-radius: 50%;\n    background: var(--red);\n  }\n  .ff-tl-item h4 {\n    font-family: var(--font-display);\n    font-size: 18px;\n    font-weight: 500;\n    margin-bottom: 4px;\n    color: var(--black);\n  }\n  .ff-tl-item p {\n    font-size: 13px;\n    color: var(--gray);\n    line-height: 1.7;\n  }\n\n  /* ═══════════ PHILOSOPHY GRID ═══════════ */\n  .ff-phil-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 28px;\n    margin-top: 44px;\n  }\n  .ff-phil-card {\n    padding: 36px 28px;\n    border: 1px solid var(--gray-border);\n    background: var(--white);\n    position: relative;\n    overflow: hidden;\n  }\n  .ff-phil-card::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0;\n    width: 100%; height: 3px;\n    background: var(--red);\n  }\n  .ff-phil-card h4 {\n    font-family: var(--font-display);\n    font-size: 21px;\n    font-weight: 400;\n    margin-bottom: 10px;\n    color: var(--black);\n  }\n  .ff-phil-card p {\n    font-size: 14px;\n    color: var(--gray);\n    line-height: 1.75;\n  }\n\n  /* ═══════════ DOC CALLOUT ═══════════ */\n  .ff-doc-callout {\n    margin-top: 44px;\n    padding: 28px 32px;\n    background: var(--white);\n    border: 1px solid var(--gray-border);\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 20px;\n  }\n  .ff-doc-callout h4 {\n    font-family: var(--font-display);\n    font-size: 19px;\n    font-weight: 400;\n    margin-bottom: 3px;\n    color: var(--black);\n  }\n  .ff-doc-callout p {\n    font-size: 13px;\n    color: var(--gray);\n  }\n  .ff-btn {\n    display: inline-block;\n    padding: 13px 36px;\n    font-size: 11px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    font-weight: 600;\n    font-family: var(--font-body);\n    transition: background 0.35s, color 0.35s, border-color 0.35s;\n    white-space: nowrap;\n    cursor: pointer;\n    text-decoration: none;\n  }\n  .ff-btn-outline {\n    border: 1px solid var(--black);\n    color: var(--black);\n    background: transparent;\n  }\n  .ff-btn-outline:hover {\n    background: var(--black);\n    color: var(--white);\n  }\n  .ff-btn-red {\n    border: 1px solid var(--red);\n    color: var(--white);\n    background: var(--red);\n  }\n  .ff-btn-red:hover {\n    background: var(--red-dark);\n    border-color: var(--red-dark);\n  }\n\n  /* ═══════════ CTA BANNER ═══════════ */\n  .ff-cta-banner {\n    text-align: center;\n    padding: 72px 40px;\n    background: var(--black);\n    color: var(--white);\n  }\n  .ff-cta-banner .ff-eyebrow { color: var(--red); }\n  .ff-cta-banner .ff-title { color: var(--white); margin-bottom: 14px; }\n  .ff-cta-banner p {\n    color: rgba(255,255,255,0.55);\n    max-width: 460px;\n    margin: 0 auto 28px;\n    font-size: 15px;\n  }\n  .ff-cta-banner .ff-btn-red { border-color: var(--red); }\n\n  /* ═══════════ ANIMATIONS ═══════════ */\n  @keyframes ffFadeUp {\n    from { opacity: 0; transform: translateY(18px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n  .ff-reveal {\n    opacity: 0;\n    transform: translateY(28px);\n    transition: opacity 0.75s ease, transform 0.75s ease;\n  }\n  .ff-reveal.ff-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* ═══════════ RESPONSIVE ═══════════ */\n  @media (max-width: 1024px) {\n    .ff-wrap { padding: 0 24px; }\n    .ff-split { grid-template-columns: 1fr; gap: 40px; }\n    .ff-split.reverse .ff-split-visual { order: 0; }\n    .ff-split.reverse .ff-split-content { order: 0; }\n    .ff-creds { grid-template-columns: repeat(2, 1fr); }\n    .ff-stab-grid { grid-template-columns: 1fr; }\n  }\n  @media (max-width: 768px) {\n    .ff-section { padding: 68px 0; }\n    .ff-hero { padding: 60px 0 48px; }\n    .ff-creds { grid-template-columns: 1fr; }\n    .ff-phil-grid { grid-template-columns: 1fr; }\n    .ff-doc-callout { flex-direction: column; text-align: center; }\n    .ff-split { gap: 32px; }\n  }\n</style>\n\n<!-- ═══════════════════════════════════════════\n     FÉRAFIVE — OUR STANDARDS PAGE CONTENT\n     Paste into Shopify Custom Liquid section\n═══════════════════════════════════════════ -->\n<div class=\"ff-standards\">\n\n  <!-- ═══════════ HERO ═══════════ -->\n  <section class=\"ff-hero\">\n    <div class=\"ff-wrap\">\n      <p class=\"ff-hero-eyebrow\">Our Standards</p>\n      <h1>The <em>Promise</em> Behind<br>Every Product</h1>\n      <p class=\"ff-hero-desc\">\n        We believe transparency is a form of respect. Every férafive product is \n        licensed, stability-tested, and manufactured to exacting standards — \n        because what you put on your skin should be worthy of your trust.\n      </p>\n    </div>\n  </section>\n\n  <!-- ═══════════ CREDENTIALS ═══════════ -->\n  <section class=\"ff-section ff-section-alt\">\n    <div class=\"ff-wrap\">\n      <div style=\"text-align:center;\" class=\"ff-reveal\">\n        <p class=\"ff-eyebrow\">Certified &amp; Verified</p>\n        <h2 class=\"ff-title\">Built on <em>credentials</em>, not claims</h2>\n      </div>\n      <div class=\"ff-creds ff-reveal\">\n        <div class=\"ff-cred-card\">\n          <div class=\"ff-cred-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M9 12l2 2 4-4\"/><path d=\"M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z\"/></svg>\n          </div>\n          <h4>FDA Licensed</h4>\n          <p>All products approved under India's Drugs &amp; Cosmetics Act, 1940. Certificate No. PD031818P.</p>\n        </div>\n        <div class=\"ff-cred-card\">\n          <div class=\"ff-cred-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 2L2 7l10 5 10-5-10-5z\"/><path d=\"M2 17l10 5 10-5\"/><path d=\"M2 12l10 5 10-5\"/></svg>\n          </div>\n          <h4>ISO 9001</h4>\n          <p>Manufactured at an ISO 9001 certified facility following international quality management systems.</p>\n        </div>\n        <div class=\"ff-cred-card\">\n          <div class=\"ff-cred-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n          </div>\n          <h4>GMP Certified</h4>\n          <p>Produced under Good Manufacturing Practice standards, ensuring consistent quality at every batch.</p>\n        </div>\n        <div class=\"ff-cred-card\">\n          <div class=\"ff-cred-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg>\n          </div>\n          <h4>Cruelty-Free &amp; Vegan</h4>\n          <p>No animal testing. No animal-derived ingredients. Clean formulations grounded in intention.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ FDA LICENSING ═══════════ -->\n  <section class=\"ff-section\">\n    <div class=\"ff-wrap\">\n      <div class=\"ff-split ff-reveal\">\n        <div class=\"ff-split-visual\">\n          <div class=\"ff-pdf-embed\">\n            <iframe src=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/FDA_Fera_Five.pdf?v=1773411542\" title=\"FDA Cosmetics Product Approval Certificate\" loading=\"lazy\"></iframe>\n            <div class=\"ff-pdf-fallback\">\n              <a href=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/FDA_Fera_Five.pdf?v=1773411542\" target=\"_blank\" rel=\"noopener\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n                Open Full Certificate\n              </a>\n            </div>\n          </div>\n        </div>\n        <div class=\"ff-split-content\">\n          <p class=\"ff-eyebrow\">Regulatory Approval</p>\n          <h2 class=\"ff-title\">Licensed under the Drugs &amp; <em>Cosmetics Act</em></h2>\n          <div class=\"ff-body\">\n            <p>\n              Every férafive product — the Hydrafusion Moisturiser, Hydrashot Serum, and Crush perfume — \n              is formally approved by the Food Safety &amp; Drug Administration, Uttar Pradesh, under \n              Licence No. UP16320000028 (Certificate No. PD031818P, dated October 2025).\n            </p>\n            <br>\n            <p>\n              This isn't a decorative seal. It means our formulations, packaging, and manufacturing \n              processes have been reviewed and cleared by a state licensing authority — every product \n              meets the legal standards required for cosmetics sold in India.\n            </p>\n            <br>\n            <p>\n              Our manufacturing partner, A.G. Organica Pvt. Ltd., holds this licence and operates \n              from their certified facility at Sector-85, Noida — equipped with ISO 9001, GMP, \n              Halal, and FSSAI credentials.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ STABILITY TESTING ═══════════ -->\n  <section class=\"ff-section ff-section-alt\">\n    <div class=\"ff-wrap\">\n      <div class=\"ff-split reverse ff-reveal\">\n        <div class=\"ff-split-content\">\n          <p class=\"ff-eyebrow\">Stability Tested</p>\n          <h2 class=\"ff-title\">90 days under <em>extreme</em> conditions</h2>\n          <div class=\"ff-body\">\n            <p>\n              Before any férafive product reaches you, it endures 90 days of accelerated stability \n              testing at 40°C and 75% relative humidity — conditions far harsher than typical Indian \n              summers.\n            </p>\n            <br>\n            <p>\n              We test appearance, colour, odour, pH, viscosity, specific gravity, \n              centrifugation, and overall integrity at every checkpoint: 14 days, 21 days, 45 days, \n              and 90 days. Every parameter must remain within specification.\n            </p>\n            <br>\n            <p>\n              The result? Products that perform consistently in your climate, \n              your routine, and your life — from the first use to the last drop.\n            </p>\n          </div>\n        </div>\n        <div class=\"ff-split-visual\">\n          <div class=\"ff-pdf-embed\">\n            <iframe src=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Hydrafusion_Moisturiser_Stability_Report.pdf?v=1773411980\" title=\"Hydrafusion Moisturiser Stability Report\" loading=\"lazy\"></iframe>\n            <div class=\"ff-pdf-fallback\">\n              <a href=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Hydrafusion_Moisturiser_Stability_Report.pdf?v=1773411980\" target=\"_blank\" rel=\"noopener\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n                Open Stability Report\n              </a>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Data Tables -->\n      <div class=\"ff-stab-grid ff-reveal\">\n        <div class=\"ff-stab-card\">\n          <div class=\"ff-stab-header\">\n            <h4>Hydrafusion Moisturiser</h4>\n            <span class=\"ff-badge\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg> All Pass</span>\n          </div>\n          <div class=\"ff-stab-body\">\n            <table>\n              <thead><tr><th>Checkpoint</th><th>pH</th><th>Viscosity (Pa.s)</th><th>Sp. Gravity</th></tr></thead>\n              <tbody>\n                <tr><td>Specification</td><td>5.00 – 6.00</td><td>5.80 – 6.50</td><td>0.99 – 1.05</td></tr>\n                <tr><td>Initial</td><td>5.60</td><td>6.10</td><td>1.0150</td></tr>\n                <tr><td>14 days</td><td>5.62</td><td>6.15</td><td>1.0152</td></tr>\n                <tr><td>21 days</td><td>5.60</td><td>6.18</td><td>1.0157</td></tr>\n                <tr><td>45 days</td><td>5.57</td><td>6.21</td><td>1.0151</td></tr>\n                <tr><td>90 days</td><td>5.65</td><td>6.27</td><td>1.0158</td></tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n        <div class=\"ff-stab-card\">\n          <div class=\"ff-stab-header\">\n            <h4>Hydrashot Serum</h4>\n            <span class=\"ff-badge\"><svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg> All Pass</span>\n          </div>\n          <div class=\"ff-stab-body\">\n            <table>\n              <thead><tr><th>Checkpoint</th><th>pH</th><th>Sp. Gravity</th><th>Status</th></tr></thead>\n              <tbody>\n                <tr><td>Specification</td><td>4.50 – 5.00</td><td>1.02 – 1.07</td><td>—</td></tr>\n                <tr><td>Initial</td><td>4.65</td><td>1.0385</td><td>Complies</td></tr>\n                <tr><td>14 days</td><td>4.69</td><td>1.0388</td><td>Complies</td></tr>\n                <tr><td>21 days</td><td>4.72</td><td>1.0392</td><td>Complies</td></tr>\n                <tr><td>45 days</td><td>4.66</td><td>1.0380</td><td>Complies</td></tr>\n                <tr><td>90 days</td><td>4.75</td><td>1.0383</td><td>Complies</td></tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ MANUFACTURING PARTNER ═══════════ -->\n  <section class=\"ff-section\">\n    <div class=\"ff-wrap\">\n      <div class=\"ff-split ff-reveal\">\n        <div class=\"ff-split-visual\">\n          <div class=\"ff-pdf-embed\" style=\"aspect-ratio:5/4;\">\n            <iframe src=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Hydrafusion_Moisturiser_MSDS.pdf?v=1773411980\" title=\"Hydrafusion Moisturiser - Material Safety Data Sheet\" loading=\"lazy\"></iframe>\n            <div class=\"ff-pdf-fallback\">\n              <a href=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Hydrafusion_Moisturiser_MSDS.pdf?v=1773411980\" target=\"_blank\" rel=\"noopener\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n                Open MSDS — Moisturiser\n              </a>\n            </div>\n          </div>\n          <div class=\"ff-pdf-embed\" style=\"aspect-ratio:5/4; margin-top: 16px;\">\n            <iframe src=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Intense_Hydration_MSDS.pdf?v=1773411979\" title=\"Intense Hydration Serum - Material Safety Data Sheet\" loading=\"lazy\"></iframe>\n            <div class=\"ff-pdf-fallback\">\n              <a href=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Intense_Hydration_MSDS.pdf?v=1773411979\" target=\"_blank\" rel=\"noopener\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n                Open MSDS — Serum\n              </a>\n            </div>\n          </div>\n        </div>\n        <div class=\"ff-split-content\">\n          <p class=\"ff-eyebrow\">Our Manufacturing Partner</p>\n          <h2 class=\"ff-title\">A.G. Organica <em>Pvt. Ltd.</em></h2>\n          <div class=\"ff-body\">\n            <p>\n              Our products are formulated and manufactured by A.G. Organica, a certified cosmetics \n              manufacturer based in Noida, Uttar Pradesh. Their facility operates under a comprehensive \n              set of quality certifications.\n            </p>\n          </div>\n          <div class=\"ff-timeline\">\n            <div class=\"ff-tl-item\">\n              <div class=\"ff-tl-dot\"></div>\n              <h4>ISO 9001 Certified</h4>\n              <p>International quality management systems governing every production process.</p>\n            </div>\n            <div class=\"ff-tl-item\">\n              <div class=\"ff-tl-dot\"></div>\n              <h4>GMP Compliant</h4>\n              <p>Good Manufacturing Practice protocols ensuring hygiene, consistency, and traceability.</p>\n            </div>\n            <div class=\"ff-tl-item\">\n              <div class=\"ff-tl-dot\"></div>\n              <h4>Halal Certified</h4>\n              <p>Ingredients and processes verified to meet Halal standards.</p>\n            </div>\n            <div class=\"ff-tl-item\">\n              <div class=\"ff-tl-dot\"></div>\n              <h4>FSSAI Registered</h4>\n              <p>Compliant with India's food safety and standards authority for applicable ingredients.</p>\n            </div>\n            <div class=\"ff-tl-item\">\n              <div class=\"ff-tl-dot\"></div>\n              <h4>ISO 22000 &amp; OneCert Organic</h4>\n              <p>Additional certifications for safety management and organic ingredient sourcing.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ INGREDIENT PHILOSOPHY ═══════════ -->\n  <section class=\"ff-section ff-section-alt\">\n    <div class=\"ff-wrap\">\n      <div style=\"text-align:center;\" class=\"ff-reveal\">\n        <p class=\"ff-eyebrow\">Ingredient Philosophy</p>\n        <h2 class=\"ff-title\">What goes in. <em>What stays out.</em></h2>\n        <p class=\"ff-body\" style=\"max-width:540px;margin:0 auto;\">\n          We formulate with intention. Every ingredient earns its place — chosen for \n          long-term skin transformation, not instant-gratification marketing.\n        </p>\n      </div>\n      <div class=\"ff-phil-grid ff-reveal\">\n        <div class=\"ff-phil-card\">\n          <h4>Purposeful Actives</h4>\n          <p>\n            Niacinamide, Sodium Hyaluronate, Squalane, Ceramide, Vitamin C, and Alpha Arbutin — \n            each selected for proven efficacy in hydration, barrier repair, and tone correction.\n          </p>\n        </div>\n        <div class=\"ff-phil-card\">\n          <h4>Botanical Intelligence</h4>\n          <p>\n            Aloe Vera, Mulberry, Licorice, Mushroom, and Tea Tree extracts work in concert — \n            soothing, brightening, and protecting without overwhelming the skin.\n          </p>\n        </div>\n        <div class=\"ff-phil-card\">\n          <h4>Clean by Design</h4>\n          <p>\n            Paraben-free. Cruelty-free. Vegan. No harsh sulphates. \n            We don't formulate for trends — we formulate for trust.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ BATCH QUALITY ═══════════ -->\n  <section class=\"ff-section\">\n    <div class=\"ff-wrap\">\n      <div class=\"ff-split reverse ff-reveal\">\n        <div class=\"ff-split-content\">\n          <p class=\"ff-eyebrow\">Batch-Level Quality</p>\n          <h2 class=\"ff-title\">Every batch is <em>individually analysed</em></h2>\n          <div class=\"ff-body\">\n            <p>\n              Before any product leaves the facility, a Certificate of Analysis is issued for that \n              specific batch — recording test results for appearance, colour, odour, pH, \n              specific gravity, viscosity, and centrifugation. Each certificate is signed off by both \n              the Q.C. Executive and the Assistant Manager of Quality Control.\n            </p>\n            <br>\n            <p>\n              This isn't a formality. It's our guarantee that the product in your hands has been \n              individually verified — not just assumed to be correct because the formula was approved once.\n            </p>\n          </div>\n        </div>\n        <div class=\"ff-split-visual\">\n          <div class=\"ff-pdf-embed\" style=\"aspect-ratio:1/1;\">\n            <iframe src=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Hydrafusion_Moisturiser.pdf?v=1773411979\" title=\"Certificate of Analysis — Hydrafusion Moisturiser\" loading=\"lazy\"></iframe>\n            <div class=\"ff-pdf-fallback\">\n              <a href=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Hydrafusion_Moisturiser.pdf?v=1773411979\" target=\"_blank\" rel=\"noopener\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n                Open COA — Moisturiser\n              </a>\n            </div>\n          </div>\n          <div class=\"ff-pdf-embed\" style=\"aspect-ratio:1/1; margin-top: 16px;\">\n            <iframe src=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Intense_Hydration.pdf?v=1773411980\" title=\"Certificate of Analysis — Hydrashot Serum\" loading=\"lazy\"></iframe>\n            <div class=\"ff-pdf-fallback\">\n              <a href=\"https://cdn.shopify.com/s/files/1/0726/6054/9803/files/Intense_Hydration.pdf?v=1773411980\" target=\"_blank\" rel=\"noopener\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n                Open COA — Serum\n              </a>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"ff-doc-callout ff-reveal\">\n        <div>\n          <h4>Need the full documentation?</h4>\n          <p>We're happy to share stability reports, MSDS sheets, and certificates of analysis upon request.</p>\n        </div>\n        <a href=\"mailto:contact@ferafive.com?subject=Documentation%20Request%20-%20F%C3%A9raFive%20Products\" class=\"ff-btn ff-btn-outline\">Request via Email</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ CTA BANNER ═══════════ -->\n  <section class=\"ff-cta-banner\">\n    <div class=\"ff-wrap\">\n      <p class=\"ff-eyebrow\">The Férafive Promise</p>\n      <h2 class=\"ff-title\">Quality you can feel. <em>Standards you can trust.</em></h2>\n      <p>Three products. One philosophy. Zero compromises.</p>\n      <a href=\"/collections/bestseller\" class=\"ff-btn ff-btn-red\">Explore the Collection</a>\n    </div>\n  </section>\n\n</div>\n\n<!-- ═══════════ SCROLL REVEAL ═══════════ -->\n<script>\n  (function(){\n    var els = document.querySelectorAll('.ff-reveal');\n    if (!els.length) return;\n    var obs = new IntersectionObserver(function(entries){\n      entries.forEach(function(e){\n        if(e.isIntersecting) e.target.classList.add('ff-visible');\n      });\n    }, { threshold: 0.12, rootMargin: '0px 0px -30px 0px' });\n    els.forEach(function(el){ obs.observe(el); });\n  })();\n</script>",
        "text_alignment": "center"
      }
    }
