{%- assign features = product.metafields.custom.product_image_with_title_and_description.value -%}
{%- if features != blank -%}

<style>
  .fs-section {
    padding: 40px 0;
    overflow: hidden;
    padding-top: 0px;
  }

  .fs-section__heading {
    text-align: center;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    margin: 0 0 40px;
    padding: 0 20px;
  }
.fs-rows {
  display: flex;
  flex-direction: column;
  gap: 60px;
  padding: 0 16px;
}

  .fs-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  justify-items: center;
  gap: 206px;
  max-width : 80%;
  margin : auto
}

  .fs-row__image {
    overflow: hidden;
    width: min(500px, 45vw);
    height: min(500px, 45vw);
    border-radius: 16px;
    flex-shrink: 0;
  }

  .fs-row__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
    transition: transform 0.6s ease;
  }

  .fs-row__image:hover .fs-row__img {
    transform: scale(1.03);
  }

  .fs-row__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px 32px;
    max-width: 580px;
  }

  .fs-row--reverse .fs-row__image { order: 2; }
  .fs-row--reverse .fs-row__content { order: 1; }

  .fs-row__seq {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .fs-row__seq-line {
    width: 32px;
    height: 2px;
    background: #000;
    display: block;
  }

  .fs-row__seq-num {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .fs-row__title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
  }

  .fs-row__text {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: #555;
    margin: 0;
  }

  .fs-carousel {
    display: none;
  }

  @media (max-width: 749px) {
    .fs-rows {
      display: none;
    }

    .fs-carousel {
      display: block;
    }

    .fs-carousel__track {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0 20px 24px;
      scroll-padding-left: 20px;
      scrollbar-width: none;
    }

    .fs-carousel__track::-webkit-scrollbar {
      display: none;
    }

    .fs-carousel__item {
      flex: 0 0 78vw;
      scroll-snap-align: start;
      display: flex;
      flex-direction: column;
    }

    .fs-carousel__img-wrap {
      width: 100%;
      aspect-ratio: 4/4;
      overflow: hidden;
      border-radius: 12px;
      margin-bottom: 20px;
    }

    .fs-carousel__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .fs-carousel__seq {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }

    .fs-carousel__seq-line {
      width: 24px;
      height: 2px;
      background: #000;
      display: block;
    }

    .fs-carousel__seq-num {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
    }

    .fs-carousel__title {
      font-size: 1.6rem;
      font-weight: 800;
      line-height: 1.1;
      text-transform: uppercase;
      letter-spacing: -0.01em;
      margin: 0 0 12px;
    }

    .fs-carousel__text {
      font-size: 14px;
      line-height: 1.6;
      color: #555;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .fs-carousel__text--expanded {
      display: block;
      -webkit-line-clamp: unset;
    }

    .fs-carousel__read-more {
      background: none;
      border: none;
      padding: 6px 0 0;
      font-size: 13px;
      font-weight: 600;
      color: #000;
      cursor: pointer;
      text-decoration: underline;
      text-align: left;
    }
  }
</style>

<section class="fs-section">

  {%- if section.settings.heading != blank -%}
    <h2 class="fs-section__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- comment -%} DESKTOP: alternating rows {%- endcomment -%}
  <div class="fs-rows">
    {%- for feature in features -%}
      {%- assign num = forloop.index | prepend: '0' -%}
      {%- assign img = feature.image.value -%}
      <div class="fs-row {% cycle 'fs-row--normal', 'fs-row--reverse' %}">
        {%- if img != blank -%}
          <div class="fs-row__image">
            {{- img | image_url: width: 1000 | image_tag:
              loading: 'lazy',
              sizes: '(max-width: 749px) 100vw, min(500px, 45vw)',
              widths: '300,400,500,600,800,1000',
              class: 'fs-row__img'
            -}}
          </div>
        {%- endif -%}
        <div class="fs-row__content">
          <div class="fs-row__seq">
            <span class="fs-row__seq-line"></span>
            <span class="fs-row__seq-num">{{ num }}</span>
          </div>
          {%- if feature.title != blank -%}
            <h3 class="fs-row__title">{{ feature.title }}</h3>
          {%- endif -%}
          {%- if feature.description != blank -%}
            <div class="fs-row__text">{{ feature.description | metafield_tag }}</div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} MOBILE: horizontal scroll carousel {%- endcomment -%}
  <div class="fs-carousel">
    <div class="fs-carousel__track">
      {%- for feature in features -%}
        {%- assign num = forloop.index | prepend: '0' -%}
        {%- assign img = feature.image.value -%}
        <div class="fs-carousel__item">
          {%- if img != blank -%}
            <div class="fs-carousel__img-wrap">
              {{- img | image_url: width: 800 | image_tag:
                loading: 'lazy',
                sizes: '78vw',
                widths: '300,400,600,800',
                class: 'fs-carousel__img'
              -}}
            </div>
          {%- endif -%}
          <div class="fs-carousel__seq">
            <span class="fs-carousel__seq-line"></span>
            <span class="fs-carousel__seq-num">{{ num }}</span>
          </div>
          {%- if feature.title != blank -%}
            <h3 class="fs-carousel__title">{{ feature.title }}</h3>
          {%- endif -%}
          {%- if feature.description != blank -%}
            <div class="fs-carousel__text" id="fs-text-{{ forloop.index }}">
              {{ feature.description | metafield_tag }}
            </div>
            <button
              class="fs-carousel__read-more"
              onclick="
                var el = document.getElementById('fs-text-{{ forloop.index }}');
                var btn = this;
                if (el.classList.contains('fs-carousel__text--expanded')) {
                  el.classList.remove('fs-carousel__text--expanded');
                  btn.textContent = 'Read more';
                } else {
                  el.classList.add('fs-carousel__text--expanded');
                  btn.textContent = 'Read less';
                }
              "
            >Read more</button>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

</section>

{%- endif -%}

{% schema %}
{
  "name": "Feature Strip",
  "tag": "section",
  "class": "shopify-section--feature-strip",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Why It Works"
    }
  ],
  "presets": [
    {
      "name": "Feature Strip"
    }
  ]
}
{% endschema %}